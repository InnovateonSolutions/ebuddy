# Bootstrap — credenciales para setup inicial
# Copiar a .bootstrap.env y completar valores reales
# .bootstrap.env está en .gitignore — NUNCA commitear

# ── DigitalOcean ──────────────────────────────────────────────
# Generar en: cloud.digitalocean.com → API → Tokens → Generate Token (read+write)
DO_TOKEN=dop_v1_REEMPLAZAR

# Generar en: cloud.digitalocean.com → API → Spaces Keys → Generate New Key
DO_SPACES_ACCESS_KEY=REEMPLAZAR
DO_SPACES_SECRET_KEY=REEMPLAZAR

# ── Supabase ──────────────────────────────────────────────────
# Access Token (para CLI):
#   supabase.com → click avatar → Account → Access Tokens → Generate new token
SUPABASE_ACCESS_TOKEN=sbp_REEMPLAZAR

# Publishable key (pública, va en el frontend):
#   Supabase dashboard → Settings → API Keys → Publishable key → copiar
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_REEMPLAZAR

# Secret key (solo servidor):
#   Supabase dashboard → Settings → API Keys → Secret keys → ojo → copiar
SUPABASE_SERVICE_ROLE_KEY=sb_secret_REEMPLAZAR

# DB Password (para migraciones):
#   Supabase dashboard → Settings → Infrastructure → Database password
SUPABASE_DB_PASSWORD=REEMPLAZAR

# ── APIs de IA ────────────────────────────────────────────────
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-REEMPLAZAR

# platform.openai.com → API Keys
OPENAI_API_KEY=sk-proj-REEMPLAZAR
