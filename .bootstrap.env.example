# Bootstrap — credenciales y secrets para setup inicial
# Copiar a .bootstrap.env y completar valores reales
# .bootstrap.env está en .gitignore — NUNCA commitear

# ── DigitalOcean ──────────────────────────────────────────────
# Generar en: cloud.digitalocean.com → API → Tokens → Generate Token (read+write)
DO_TOKEN=dop_v1_REEMPLAZAR

# Generar en: cloud.digitalocean.com → API → Spaces Keys → Generate New Key
DO_SPACES_ACCESS_KEY=REEMPLAZAR
DO_SPACES_SECRET_KEY=REEMPLAZAR

# ── Base de datos y auth ──────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require
AUTH_SECRET=REEMPLAZAR
RESEND_API_KEY=
EMAIL_FROM=ebuddy <noreply@ebuddy.io>

# ── APIs de IA ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-REEMPLAZAR
OPENAI_API_KEY=sk-proj-REEMPLAZAR

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://ebuddy.innovateoncorp.com
DO_MONITORING_TOKEN=
CRON_SECRET=
OLLAMA_BASE_URL=
OPENCLAW_BASE_URL=
OPENCLAW_HOOK_TOKEN=
OPENCLAW_GATEWAY_TOKEN=

# ── Calendario Google (opcional) ─────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://ebuddy.innovateoncorp.com/api/auth/calendar/google/callback

# ── Calendario Microsoft (opcional) ──────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=https://ebuddy.innovateoncorp.com/api/auth/calendar/microsoft/callback

# ── Operación y conectividad adicional (opcionales) ──────────
TAILSCALE_AUTH_KEY=
ELITEMINI_SSH_KEY=

# ── WhatsApp / OpenClaw (opcionales) ─────────────────────────
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_TOKEN=
WHATSAPP_OWNER_USER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
