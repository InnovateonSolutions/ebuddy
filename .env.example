# ══════════════════════════════════════════════════════════════
# ebuddy — Variables de entorno
# Copia este archivo a .env y llena los valores reales.
# .env está en .gitignore — nunca se commitea.
# ══════════════════════════════════════════════════════════════

# ── DigitalOcean (solo para terraform apply local) ────────────
DO_TOKEN=dop_v1_...
DO_SPACES_ACCESS_KEY=DO007...
DO_SPACES_SECRET_KEY=...

# ── Base de datos (DO Managed PostgreSQL) ─────────────────────
DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require

# ── Auth.js ───────────────────────────────────────────────────
AUTH_SECRET=...                          # openssl rand -base64 32
RESEND_API_KEY=re_...                    # para magic links por email
EMAIL_FROM=ebuddy <noreply@ebuddy.io>

# ── AI ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://app.ebuddy.io
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=true      # muestra botón de Google en /login

# ── Calendario Google (opcional — dejar vacío si no se usa) ───
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://app.ebuddy.io/api/auth/calendar/google/callback

# ── Calendario Microsoft (opcional — dejar vacío si no se usa)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=https://app.ebuddy.io/api/auth/calendar/microsoft/callback
